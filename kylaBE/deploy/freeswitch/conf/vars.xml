<include>
  <!-- Kyla-specific FreeSWITCH variables.
       Override per-environment via docker-compose env, not by editing this file. -->
  <X-PRE-PROCESS cmd="set" data="domain=$${local_ip_v4}"/>
  <X-PRE-PROCESS cmd="set" data="domain_name=$${domain}"/>

  <!-- Default codec offer order. PCMU/PCMA for PSTN compatibility; OPUS for
       browser softphones via the webrtc profile. -->
  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=OPUS,G722,PCMU,PCMA"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=PCMU,PCMA,G722,OPUS"/>

  <!-- ESL password the Go telephony service uses to authenticate.
       The docker-compose service exposes this via FS_ESL_PASSWORD. -->
  <X-PRE-PROCESS cmd="set" data="default_password=ClueCon"/>

  <!-- SIP transport defaults. The internal profile listens on 5060;
       the webrtc profile listens on 7443 for SIP-over-WSS. -->
  <X-PRE-PROCESS cmd="set" data="internal_sip_port=5060"/>
  <X-PRE-PROCESS cmd="set" data="webrtc_wss_port=7443"/>

  <!-- Recording path on the container volume (mapped to freeswitch_recordings). -->
  <X-PRE-PROCESS cmd="set" data="recordings_dir=/var/lib/freeswitch/recordings"/>
</include>
