<configuration name="event_socket.conf" description="Socket Client">
  <!-- ESL endpoint the Go telephony service connects to. The bind address
       0.0.0.0 is safe within the Docker network; the docker-compose service
       only exposes 8021 to the host for local development. -->
  <settings>
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="0.0.0.0"/>
    <param name="listen-port" value="8021"/>
    <param name="password" value="$${default_password}"/>
    <!-- Allow only RFC1918 + loopback by default. Override with apply-inbound-acl
         once a stricter ACL is defined. -->
    <param name="apply-inbound-acl" value="rfc1918.auto"/>
    <param name="stop-on-bind-error" value="true"/>
  </settings>
</configuration>
