# ── Runtime ────────────────────────────────────────────────────────────────
ENVIRONMENT=local
PORT=50050
JWT_SECRET_KEY=change-me-in-prod

# ── Postgres (must match envs/postgres.env) ────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kyla
POSTGRES_USER=kyla
POSTGRES_PASS=kyla

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379
REDIS_PASSWORD=kyla_redis
REDIS_DB=0
# Legacy variables some code paths still read.
REDIS_HOST=redis
REDIS_PORT=6379

# ── NATS ───────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_HOST_PORT=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=kyla-automation

# ── Firebase (base64-encoded service account JSON) ─────────────────────────
FB_CREDENTIALS=

# ── WebAuthn ───────────────────────────────────────────────────────────────
WEB_AUTHN_RP_ID=localhost
WEB_AUTHN_RP_ORIGIN=http://localhost
WEB_AUTHN_RP_DISPLAY_NAME=Kyla

# ── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_BASE_URL=
RESEND_SUPPORT_EMAIL=

# ── AWS (SQS + other AWS-backed integrations) ──────────────────────────────
AWS_REGION=eu-west-3
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ── Outbound gRPC clients ──────────────────────────────────────────────────
LEADS_ADDRESS=
AUTH_SVC_URL=

# ── WhatsApp Business API ──────────────────────────────────────────────────
WA_WEBHOOK_SECRET=
WA_VERIFY_TOKEN=
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# ── Email channel (IMAP poll + SMTP send) ──────────────────────────────────
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_POLL_INTERVAL_SECS=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMS channel ────────────────────────────────────────────────────────────
SMS_PROVIDER=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

AT_API_KEY=
AT_USERNAME=
AT_FROM=

# ── SLA scanner ────────────────────────────────────────────────────────────
SLA_SCAN_INTERVAL_SECS=60

# ── LLM provider (openai | anthropic | noop) ───────────────────────────────
LLM_PROVIDER=noop
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ── FreeSWITCH (ESL + WebRTC) ──────────────────────────────────────────────
FS_ESL_HOST=freeswitch
FS_ESL_PORT=8021
FS_ESL_PASSWORD=ClueCon
FS_WSS_URL=wss://localhost:7443
FS_SIP_REALM=kyla
FS_DEFAULT_TRUNK=

# ── coturn (browser WebRTC NAT traversal) ──────────────────────────────────
TURN_URL=turn:localhost:3478
TURN_USERNAME=kyla
TURN_PASSWORD=kylaturn
