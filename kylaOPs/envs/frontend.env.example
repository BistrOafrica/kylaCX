# Build-time variables for the Vite SPA. These are baked into the static
# bundle at image-build time — changing them requires `make build-frontend`.
#
# In compose these are passed via build.args from the top-level .env, NOT
# via env_file. This file documents the canonical names and defaults.

# Backend gRPC-web gateway. The default `/grpc` is rewritten by the public
# nginx (docker/frontend/nginx.conf) to proxy to envoy. Override if the SPA
# is served on a different origin than the API.
VITE_API_URL=/grpc

# Sentry DSN — leave empty for local dev.
VITE_SENTRY_DSN=

# Environment label surfaced in the UI (local | staging | production).
VITE_ENVIRONMENT=local
