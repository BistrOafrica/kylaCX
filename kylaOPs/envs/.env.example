# Top-level compose env — read automatically by docker compose from kylaOPs/.env
# Holds host-port mappings and frontend build-args (those can't use env_file
# because they need to be baked at image-build time).

# ── Public host-port mappings ──────────────────────────────────────────────
FRONTEND_HOST_PORT=80
WEBHOOK_HOST_PORT=8080

# ── Frontend build-args (forwarded to docker build via compose) ────────────
VITE_API_URL=/grpc
VITE_SENTRY_DSN=
VITE_ENVIRONMENT=local

# ── Compose project name override (optional) ───────────────────────────────
# COMPOSE_PROJECT_NAME=kyla
