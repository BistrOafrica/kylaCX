    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "proto": "protoc --plugin=./node_modules/.bin/protoc-gen-ts --ts_opt generate_dependencies --ts_opt ts_nocheck --ts_opt optimize_code_size --ts_out ./src/pb --proto_path ../kylaPB ../kylaPB/*.proto --experimental_allow_proto3_optional"
